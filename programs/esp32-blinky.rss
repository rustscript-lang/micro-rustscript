use gpio;
use mcu;
use serial;

let led_pin = 8;
let configured: bool = gpio::configure(led_pin, 1);
let mut high = false;
let mut count = 0;
while configured && count < 4 {
    high = !high;
    let written: bool = gpio::digital_write(led_pin, high);
    if !written {
        count = 4;
    } else {
        mcu::delay_ms(100);
        count = count + 1;
    }
}

if gpio::digital_read(led_pin) {
    serial::write_line("micro-rustscript:gpio=high");
} else {
    serial::write_line("micro-rustscript:gpio=low");
}
