fn __esp32_i2c_begin(sda: int, scl: int, frequency: int) -> bool;
fn __esp32_i2c_end() -> null;
fn __esp32_i2c_write(address: int, data: bytes) -> int;
fn __esp32_i2c_write_register(address: int, register: int, data: bytes) -> int;
fn __esp32_i2c_read(address: int, length: int) -> bytes;
fn __esp32_i2c_read_register(address: int, register: int, length: int) -> bytes;

pub fn open(sda: int, scl: int, frequency: int) -> bool {
    __esp32_i2c_begin(sda, scl, frequency)
}

pub fn close() -> null {
    __esp32_i2c_end()
}

// Returns the Wire endTransmission status code.
pub fn transmit(address: int, data: bytes) -> int {
    __esp32_i2c_write(address, data)
}

pub fn transmit_register(address: int, register: int, data: bytes) -> int {
    __esp32_i2c_write_register(address, register, data)
}

// Receives at most 255 bytes.
pub fn receive(address: int, length: int) -> bytes {
    __esp32_i2c_read(address, length)
}

pub fn receive_register(address: int, register: int, length: int) -> bytes {
    __esp32_i2c_read_register(address, register, length)
}
