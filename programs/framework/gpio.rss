fn __esp32_gpio_configure(pin: int, mode: int) -> bool;
fn __esp32_gpio_write(pin: int, high: bool) -> bool;
fn __esp32_gpio_read(pin: int) -> bool;
fn __esp32_gpio_analog_read(pin: int) -> int;
fn __esp32_gpio_pwm(pin: int, duty: int, frequency: int, resolution_bits: int) -> bool;

// mode: 0=input, 1=output, 2=input pull-up, 3=input pull-down, 4=open-drain output.
pub fn configure(pin: int, mode: int) -> bool {
    __esp32_gpio_configure(pin, mode)
}

pub fn digital_write(pin: int, high: bool) -> bool {
    __esp32_gpio_write(pin, high)
}

pub fn digital_read(pin: int) -> bool {
    __esp32_gpio_read(pin)
}

pub fn analog_read(pin: int) -> int {
    __esp32_gpio_analog_read(pin)
}

pub fn pwm_write(pin: int, duty: int, frequency: int, resolution_bits: int) -> bool {
    __esp32_gpio_pwm(pin, duty, frequency, resolution_bits)
}
